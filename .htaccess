# Запрет доступа к конфигурационным файлам
<FilesMatch "^(config\.php|config\.example\.php|\.git|\.htaccess|generate_icons\.php)">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Запрет листинга директорий
Options -Indexes

# Запрет доступа к скрытым файлам и папкам
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule "(^|/)\.(?!well-known)" - [F]
</IfModule>
